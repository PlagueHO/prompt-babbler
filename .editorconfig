root = true

[*.{ts,tsx,js,jsx,json,jsonc,yml,yaml,md,css,scss,bicep,bicepparam}]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.cs]
indent_style = space
indent_size = 4

[*.ps1]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false