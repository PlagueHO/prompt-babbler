{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/PlagueHO/prompt-babbler/prompt-template.schema.json",
  "title": "Prompt Template Definition",
  "description": "Schema for built-in prompt template definition files used by PromptBabbler.",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "id",
    "name",
    "description",
    "instructions"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to the JSON Schema file for validation."
    },
    "schemaVersion": {
      "type": "string",
      "description": "Version of the prompt template schema this file conforms to.",
      "pattern": "^\\d+\\.\\d+$"
    },
    "id": {
      "type": "string",
      "description": "Unique identifier for the built-in template.",
      "pattern": "^builtin-[a-z0-9-]+$",
      "minLength": 1,
      "maxLength": 100
    },
    "name": {
      "type": "string",
      "description": "Display name of the template.",
      "minLength": 1,
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "description": "Brief description of what the template does.",
      "minLength": 1,
      "maxLength": 1000
    },
    "instructions": {
      "type": "string",
      "description": "Core instructions for the LLM. This is the primary directive that tells the model what to do.",
      "minLength": 1,
      "maxLength": 50000
    },
    "outputDescription": {
      "type": "string",
      "description": "Describes the desired characteristics of the output.",
      "maxLength": 2000
    },
    "outputTemplate": {
      "type": "string",
      "description": "A text or markdown format template for the output structure.",
      "maxLength": 10000
    },
    "examples": {
      "type": "array",
      "description": "Few-shot examples as input/output pairs.",
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["input", "output"],
        "additionalProperties": false,
        "properties": {
          "input": {
            "type": "string",
            "description": "Sample babble input.",
            "minLength": 1,
            "maxLength": 5000
          },
          "output": {
            "type": "string",
            "description": "Desired prompt output for the sample input.",
            "minLength": 1,
            "maxLength": 10000
          }
        }
      }
    },
    "guardrails": {
      "type": "array",
      "description": "Don't-do constraints for the LLM.",
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "defaultOutputFormat": {
      "type": "string",
      "description": "Default output format. Can be overridden per request.",
      "enum": ["text", "markdown"]
    },
    "defaultAllowEmojis": {
      "type": "boolean",
      "description": "Default emoji preference. Can be overridden per request."
    },
    "tags": {
      "type": "array",
      "description": "Categorization tags for the template.",
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 50
      }
    }
  }
}
